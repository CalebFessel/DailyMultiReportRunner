# =============================
# PARAM / MARKER HELPERS
# =============================
def _sql_marker_count(sql: str) -> int:
    """Count ODBC positional parameters ('?') in the SQL string."""
    return sql.count("?")


def _normalize_params(params):
    """
    Normalize params into a list.
    Accepts: None, scalar, tuple/list.
    """
    if params is None:
        return []
    if isinstance(params, (list, tuple)):
        return list(params)
    return [params]


def _expand_params_to_markers(sql: str, params, label: str = "SQL"):
    """
    Ensure params length matches number of '?' markers in sql.

    Rules:
    - If markers == 0 -> []
    - If params length matches -> params
    - If params is length 1 and markers > 1 -> repeat
    - If markers divisible by len(params) -> repeat pattern
    - Else: raise
    """
    markers = _sql_marker_count(sql)
    p = _normalize_params(params)
    if markers == 0:
        return []
    if len(p) == markers:
        return p
    if len(p) == 1 and markers > 1:
        return p * markers
    if len(p) > 0 and markers % len(p) == 0:
        return p * (markers // len(p))
    raise ValueError(f"[{label}] Parameter mismatch: SQL markers={markers}, params_len={len(p)}")


# =============================
# SQL - OTP (MySQL-compatible)
# =============================
def build_sql_otp_queries():
    """
    Dedup strategy:
    - Build a leg-level base rowset (may have multiple rows per run_id).
    - Create a deterministic pick_key: pickup_time + leg.id (tie-break).
    - For each run_id, choose MIN(pick_key), join back to get exactly one row per run_id.
    """
    sql_otp_base = r"""
    SELECT
        ep.run_id,
        rev.unit_id,
        rev.calltype_id,
        rev.pickup_time,
        ep.field_value,
        CONCAT(
            DATE_FORMAT(rev.pickup_time,'%Y%m%d%H%i%s'),
            '-',
            LPAD(leg.id, 10, '0')
        ) AS pick_key
    FROM cad_trip_legs leg
    INNER JOIN cad_trip_legs_rev rev
        ON rev.leg_id = leg.id AND rev.rev = leg.rev
    /* Pre-filter ePCR to the same reporting window using a date field */
    INNER JOIN (
        SELECT
            r.id AS run_id,
            r.run_num,
            v.field_value
        FROM epcr_v2_runs r
        INNER JOIN epcr_v2_custom_configs cfg
            ON cfg.id = r.config_id
           AND cfg.field_table_id = 3
        INNER JOIN (
            SELECT run_id, MIN(field_value) AS field_value
            FROM epcr_v2_values
            WHERE field_id = 549
            GROUP BY run_id
        ) v ON v.run_id = r.id
        WHERE r.deleted = 0
          AND STR_TO_DATE(v.field_value, '%Y-%m-%d %H:%i:%s') >= ?
          AND STR_TO_DATE(v.field_value, '%Y-%m-%d %H:%i:%s') < ?
    ) ep
        ON ep.run_num = leg.run_number
    WHERE rev.pickup_time >= ?
      AND rev.pickup_time < ?
      AND rev.last_status_id IN (2,3,4,5,6,7)
    """

    sql_otp_dedup = r"""
    SELECT
        b.run_id,
        b.unit_id,
        b.calltype_id,
        b.pickup_time,
        b.field_value
    FROM ({base}) b
    INNER JOIN (
        SELECT run_id, MIN(pick_key) AS min_pick_key
        FROM ({base}) x
        GROUP BY run_id
    ) d
        ON d.run_id = b.run_id AND d.min_pick_key = b.pick_key
    """.format(base=sql_otp_base)

    sql_uniq_cc = r"""
    SELECT stsa.unit_id, MIN(su.cost_center_id) AS cost_center_id
    FROM sched_template_shift_assignments stsa
    INNER JOIN sched_units su ON su.id = stsa.unit_id
    WHERE stsa.deleted = 0
    GROUP BY stsa.unit_id
    """

    sql_scored = r"""
    SELECT
        one.run_id,
        one.unit_id,
        one.calltype_id,
        CASE
            WHEN one.pickup_time IS NULL OR one.field_value IS NULL THEN 'Missing Data'
            WHEN TIMESTAMPDIFF(
                MINUTE,
                one.pickup_time,
                STR_TO_DATE(one.field_value, '%Y-%m-%d %H:%i:%s')
            ) BETWEEN -10 AND 10 THEN 'On Time'
            WHEN TIMESTAMPDIFF(
                MINUTE,
                one.pickup_time,
                STR_TO_DATE(one.field_value, '%Y-%m-%d %H:%i:%s')
            ) < -10 THEN 'Early'
            ELSE 'Late'
        END AS status
    FROM ({dedup}) one
    """.format(dedup=sql_otp_dedup)

    excluded_list = ",".join("'" + x.replace("'", "''") + "'" for x in OTP_EXCLUDED_COST_CENTERS)

    sql_by_calltype = r"""
    SELECT
        COALESCE(TRIM(cc.name), 'No Cost Center Assigned') AS cost_center,
        COALESCE(calltype.name, 'Unknown Call Type') AS call_type,
        COUNT(*) AS total_runs,
        SUM(s.status = 'Early') AS early_runs,
        SUM(s.status = 'On Time') AS on_time_runs,
        SUM(s.status = 'Late') AS late_runs,
        ROUND(
            100 * (SUM(s.status = 'On Time') + SUM(s.status = 'Early')) / COUNT(*),
            2
        ) AS on_time_percentage
    FROM ({scored}) s
    LEFT JOIN ({uniq_cc}) ucc ON ucc.unit_id = s.unit_id
    LEFT JOIN cost_centers cc ON cc.id = ucc.cost_center_id
    LEFT JOIN sched_unit_types calltype ON calltype.id = s.calltype_id
    WHERE (cc.name IS NULL OR cc.name NOT IN ({excluded}))
    GROUP BY
        COALESCE(TRIM(cc.name), 'No Cost Center Assigned'),
        COALESCE(calltype.name, 'Unknown Call Type')
    ORDER BY cost_center, on_time_percentage DESC;
    """.format(scored=sql_scored, uniq_cc=sql_uniq_cc, excluded=excluded_list)

    sql_by_costcenter = r"""
    SELECT
        COALESCE(TRIM(cc.name), 'No Cost Center Assigned') AS cost_center,
        COUNT(*) AS total_runs,
        SUM(s.status = 'Early') AS early_runs,
        SUM(s.status = 'On Time') AS on_time_runs,
        SUM(s.status = 'Late') AS late_runs,
        ROUND(
            100 * (SUM(s.status = 'On Time') + SUM(s.status = 'Early')) / COUNT(*),
            2
        ) AS on_time_percentage
    FROM ({scored}) s
    LEFT JOIN ({uniq_cc}) ucc ON ucc.unit_id = s.unit_id
    LEFT JOIN cost_centers cc ON cc.id = ucc.cost_center_id
    WHERE (cc.name IS NULL OR cc.name NOT IN ({excluded}))
    GROUP BY COALESCE(TRIM(cc.name), 'No Cost Center Assigned')
    ORDER BY on_time_percentage DESC;
    """.format(scored=sql_scored, uniq_cc=sql_uniq_cc, excluded=excluded_list)

    return sql_by_calltype, sql_by_costcenter


SQL_OTP_BY_CALLTYPE, SQL_OTP_BY_COSTCENTER = build_sql_otp_queries()

