def window_midnight(report_end_date=None, now_dt=None):
    """
    Returns (window_start, window_end) for a midnight → midnight reporting window.

    - Default behavior (no CLI date): run for yesterday (00:00 → today 00:00).
    - Backfill behavior: if CLI YYYY-MM-DD is provided, that day 00:00 → next day 00:00.
    """
    if now_dt is None:
        now_dt = datetime.now()
    if report_end_date is None:
        day = now_dt.date() - timedelta(days=1)
    else:
        day = report_end_date
    window_start = datetime.combine(day, time(0, 0))
    window_end = window_start + timedelta(days=1)
    return window_start, window_end


def parse_cli_end_date(argv):
    """
    Parses an optional YYYY-MM-DD date from argv, ignoring flags like --no-email.
    Returns a date or None.
    """
    for arg in argv[1:]:
        if arg.startswith("-"):
            continue
        try:
            return datetime.strptime(arg.strip(), "%Y-%m-%d").date()
        except ValueError:
            continue
    return None


def has_flag(argv, flag: str) -> bool:
    flag = flag.lower()
    return any(a.lower() == flag for a in argv[1:])


