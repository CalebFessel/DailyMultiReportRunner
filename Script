def report_companywide_otp(window_start, window_end, run_date_str):
    conn = get_db_connection()
    try:
        otp_params = _expand_params_to_markers(
            SQL_OTP_BY_CALLTYPE, [window_start, window_end], label="OTP_CALLTYPE"
        )
        df_calltype = pd.read_sql_query(SQL_OTP_BY_CALLTYPE, conn, params=otp_params)

        otp_params2 = _expand_params_to_markers(
            SQL_OTP_BY_COSTCENTER, [window_start, window_end], label="OTP_COSTCENTER"
        )
        df_costcenter = pd.read_sql_query(SQL_OTP_BY_COSTCENTER, conn, params=otp_params2)
    finally:
        conn.close()

    recon = None
    if ENABLE_OTP_RECONCILIATION_SHEET:
        ct = (
            df_calltype.groupby("cost_center", as_index=False)["total_runs"]
            .sum()
            .rename(columns={"total_runs": "calltype_sum"})
        )
        cc = df_costcenter[["cost_center", "total_runs"]].rename(
            columns={"total_runs": "costcenter_total"}
        )
        recon = ct.merge(cc, on="cost_center", how="outer").fillna(0)
        recon["diff"] = recon["calltype_sum"] - recon["costcenter_total"]
        bad = recon[recon["diff"] != 0]
        if not bad.empty:
            logging.warning("OTP reconciliation mismatch found:\n%s", bad.to_string(index=False))

    out_path = os.path.join(OUTPUT_DIR, f"CompanyWide_OTP_{run_date_str}.xlsx")
    with pd.ExcelWriter(out_path, engine="openpyxl") as writer:
        write_df_sheet_with_table(
            writer, df_calltype, "OTP by Call Type", f"OTP_CallType_{run_date_str}"
        )
        write_df_sheet_with_table(
            writer, df_costcenter, "OTP by Cost Center", f"OTP_CostCenter_{run_date_str}"
        )
        if recon is not None:
            write_df_sheet_with_table(
                writer, recon, "OTP Reconciliation", f"OTP_Recon_{run_date_str}"
            )

    append_path = os.path.join(APPEND_DIR, "CompanyWide_OTP_APPEND.xlsx")
    _append_to_workbook_xlsx(
        append_path,
        "OTP by Call Type",
        df_calltype,
        dedupe_keys=["snapshot_date", "cost_center", "call_type"],
        snapshot_date_value=run_date_str,
    )
    _append_to_workbook_xlsx(
        append_path,
        "OTP by Cost Center",
        df_costcenter,
        dedupe_keys=["snapshot_date", "cost_center"],
        snapshot_date_value=run_date_str,
    )
    if recon is not None:
        _append_to_workbook_xlsx(
            append_path,
            "OTP Reconciliation",
            recon,
            dedupe_keys=["snapshot_date", "cost_center"],
            snapshot_date_value=run_date_str,
        )

    return f"CallType={len(df_calltype)}, CostCenter={len(df_costcenter)}", out_path


