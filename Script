        write_df_sheet_with_table(
            writer, df, "UHU by Shift Profile", f"UHU_ShiftProfile_{run_date_str}"
        )

    append_path = os.path.join(APPEND_DIR, "Daily_UHU_By_Shift_Profile_APPEND.xlsx")
    keys = ["work_date", "schedule_id"] if "schedule_id" in df.columns else [
        "work_date",
        "shift_profile_name",
    ]
    _append_to_workbook_xlsx(
        append_path,
        "UHU by Shift Profile",
        df,
        dedupe_keys=keys,
        snapshot_date_value=None,
    )

    return f"Rows={len(df)}", out_path


# =============================
# MAIN
# =============================
def main():
    tz = ZoneInfo("America/New_York")
    now_local = datetime.now(tz)
    now_local_naive = now_local.replace(tzinfo=None)

    report_end_date = parse_cli_end_date(sys.argv)

    window_start, window_end = window_midnight(report_end_date, now_dt=now_local_naive)

    metrics_date = window_start.date()
    metrics_date_str = metrics_date.isoformat()

    if report_end_date is None:
        staffing_asof = now_local_naive
        staffing_tomorrow_date = now_local.date() + timedelta(days=1)
        vehicle_date = now_local.date()
    else:
        staffing_asof = window_end - timedelta(seconds=1)
        staffing_tomorrow_date = metrics_date + timedelta(days=1)
        vehicle_date = metrics_date

    staffing_date_str = staffing_asof.date().isoformat()
    vehicle_date_str = vehicle_date.isoformat()

    no_email = has_flag(sys.argv, "--no-email")

    Path(OUTPUT_DIR).mkdir(parents=True, exist_ok=True)
    Path(APPEND_DIR).mkdir(parents=True, exist_ok=True)

    log_path = setup_logging(OUTPUT_DIR, metrics_date_str)

    logging.info("=== Daily Multi-Report Runner Started ===")
    logging.info("NOW_LOCAL=%s", now_local.isoformat())
    logging.info("Window: %s -> %s | METRICS_DATE=%s", window_start, window_end, metrics_date_str)
    logging.info("STAFFING asof=%s | STAFFING tomorrow=%s", staffing_asof, staffing_tomorrow_date)
    logging.info("VEHICLE date=%s", vehicle_date)
    logging.info("DB_DSN=%s | TEST_MODE=%s", DB_DSN, TEST_MODE)
    logging.info("APPEND_DIR=%s", APPEND_DIR)

    reports = [
        ("CompanyWide OTP", lambda: report_companywide_otp(window_start, window_end, metrics_date_str)),
        ("Staffing Report", lambda: report_staffing(staffing_asof, staffing_tomorrow_date, staffing_date_str)),
        ("Daily Vehicle Overview", lambda: report_daily_vehicle_overview(vehicle_date, vehicle_date_str)),
        ("UHU by Cost Center", lambda: report_uhu_by_cost_center(window_start, window_end, metrics_date, metrics_date_str)),
        ("UHU by Shift Profile", lambda: report_uhu_by_shift_profile(window_start, window_end, metrics_date, metrics_date_str)),
    ]

    results = []
    attachments = []

    for name, fn in reports:
        ok, rows_info, path, err = run_one_report(name, fn)
        results.append((name, ok, rows_info, path, err))
        if ok and path:
            attachments.append(path)

    lines = [
        f"Daily Reports Bundle - {metrics_date_str}",
        f"Window: {window_start} -> {window_end}",
        f"Output Folder: {OUTPUT_DIR}",
        f"Append Folder: {APPEND_DIR}",
        f"Log File: {log_path}",
        "",
    ]

    for name, ok, rows_info, path, err in results:
        if ok:
            lines.append(f"✅ {name}: {rows_info}")
            lines.append(f"  {path}")
        else:
            lines.append(f"❌ {name}: FAILED")
            lines.append(f"  {err}")
        lines.append("")

    body = "\n".join(lines)

    recipients = [TEST_MODE_RECIPIENT] if TEST_MODE else PROD_RECIPIENTS
    test_suffix = " [TEST]" if TEST_MODE else ""
    subject = EMAIL_SUBJECT.format(date=metrics_date_str, test_suffix=test_suffix)

    if no_email:
        logging.info("NO_EMAIL enabled (--no-email). Skipping main and status emails.")
    else:
        email_error = None
        try:
            send_email(subject, body, recipients, attachments=attachments)
        except Exception as e:
            email_error = str(e)
            logging.error(f"Main email send failed: {e}", exc_info=True)

        status_subject = f"STATUS - {subject}" + (" (EMAIL FAILED)" if email_error else "")
        status_body = body + (f"\n\nMAIN EMAIL ERROR:\n{email_error}\n" if email_error else "")
        try:
            send_email(status_subject, status_body, [STATUS_EMAIL_RECIPIENT], attachments=None)
        except Exception as e:
            logging.error(f"Status email failed: {e}", exc_info=True)

    if not TEST_MODE:
        cleanup_old_files()

    logging.info("=== Daily Multi-Report Runner Completed ===")


# =============================
# STATUS LOGGER WRAP + ENTRYPOINT
# =============================
if __name__ == "__main__":
    JOB_NAME = "Daily_MultiReport_Runner"
    run_id = None
    cnxn_status = None

    try:
        try:
            from status_logger import (
                get_cnxn,
                get_job_id,
                start_run,
                finish_run,
                STATUS_SUCCESS,
                STATUS_FAILED,
            )
        except ImportError:
            get_cnxn = get_job_id = start_run = finish_run = None
            STATUS_SUCCESS = STATUS_FAILED = None

        if get_cnxn is not None:
            cnxn_status = get_cnxn()
            job_id = get_job_id(cnxn_status, JOB_NAME)
            run_id = start_run(cnxn_status, job_id)
    except Exception as e:
        logging.error("Status dashboard logging init failed: %s", e, exc_info=True)

    try:
        main()
        if run_id is not None and cnxn_status is not None and finish_run is not None:
            try:
                finish_run(
                    cnxn_status,
                    run_id,
                    STATUS_SUCCESS,
                    row_count=None,
                    output_file=None,
                    error_message=None,
                )
            except Exception as e2:
                logging.error("Status dashboard finish_run failed: %s", e2, exc_info=True)

    except Exception as e:
        err = str(e)
        logging.error("Unhandled exception in Daily_MultiReport_Runner: %s", e, exc_info=True)
        if run_id is not None and cnxn_status is not None and finish_run is not None:
            try:
                finish_run(
                    cnxn_status,
                    run_id,
                    STATUS_FAILED,
                    row_count=None,
                    output_file=None,
                    error_message=err,
                )
            except Exception as e2:
                logging.error("Status dashboard finish_run failed: %s", e2, exc_info=True)
        raise
    finally:
        try:
            if cnxn_status is not None:
                cnxn_status.close()
        except Exception:
            pass
