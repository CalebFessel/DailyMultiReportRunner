                GREATEST(
                    0,
                    TIMESTAMPDIFF(
                        MINUTE,
                        GREATEST(stsa.start_time, ?),
                        LEAST(stsa.end_time, ?)
                    )
                ) AS overlap_minutes
            FROM sched_template_shift_assignments stsa
            JOIN sched_schedules ss
                ON ss.id = stsa.schedule_id
            WHERE
                stsa.user_id > 0
                AND stsa.deleted = '0'
                AND stsa.schedule_type = 'template'
                AND ss.name NOT LIKE '%Dispatch%'
                AND ss.name NOT LIKE '%Comm%'
                AND ss.name NOT LIKE '%Call%'
                AND stsa.end_time > ?
                AND stsa.start_time < ?
            GROUP BY
                stsa.schedule_id,
                ss.name,
                stsa.unit_id,
                stsa.start_time,
                stsa.end_time
        ) x
        GROUP BY x.schedule_id, x.shift_profile_name
    ) prof
    LEFT JOIN (
        SELECT
            t.schedule_id,
            t.shift_profile_name,
            SUM(t.leg_minutes) / 60 AS loaded_hours,
            COUNT(*) AS total_runs
        FROM (
            SELECT
                leg.id AS leg_id,
                MIN(stsa.schedule_id) AS schedule_id,
                MIN(ss.name) AS shift_profile_name,
                (COALESCE(cu.est_trip_duration,0) + COALESCE(cu.shifted_amount,0)) AS leg_minutes
            FROM cad_trip_legs leg
            JOIN cad_trip_legs_rev rev
                ON rev.leg_id = leg.id
               AND rev.rev = leg.rev
            JOIN cad_trip_leg_shift_assignments sa
                ON sa.leg_id = leg.id
            JOIN sched_template_shift_assignments stsa
                ON stsa.id = sa.shift_assignment_id
            JOIN sched_schedules ss
                ON ss.id = stsa.schedule_id
            LEFT JOIN cad_unit_schedules cu
                ON cu.leg_id = leg.id
               AND cu.block_id IS NULL
            WHERE
                rev.deleted = 0
                AND rev.last_status_id IN (1,2,3,4,5,6,7)
                AND stsa.user_id > 0
                AND stsa.deleted = '0'
                AND stsa.schedule_type = 'template'
                AND ss.name NOT LIKE '%Dispatch%'
                AND ss.name NOT LIKE '%Comm%'
                AND ss.name NOT LIKE '%Call%'
                AND rev.pickup_time >= ?
                AND rev.pickup_time < ?
            GROUP BY leg.id
        ) t
        GROUP BY t.schedule_id, t.shift_profile_name
    ) ld
        ON ld.schedule_id = prof.schedule_id
) sp
JOIN sched_schedules ss
    ON ss.id = sp.schedule_id
JOIN cost_centers cc
    ON cc.id = ss.cost_center_id
GROUP BY cc.id, cc.name
ORDER BY uhu_ratio DESC;
"""

